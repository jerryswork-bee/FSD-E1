<?php
$conn = new mysqli("localhost", "root", "", "student_db");

if ($conn->connect_error) {
    die("Connection failed: " . $conn->connect_error);
}

// Sorting
$order = "";
if (isset($_GET['sort'])) {
    if ($_GET['sort'] == "name") {
        $order = "ORDER BY name ASC";
    } elseif ($_GET['sort'] == "dob") {
        $order = "ORDER BY dob ASC";
    }
}

// Filtering
$where = "";
if (isset($_GET['department']) && $_GET['department'] != "") {
    $dept = $_GET['department'];
    $where = "WHERE department='$dept'";
}

// Fetch Data
$result = $conn->query("SELECT * FROM students $where $order");

// Count per department
$countResult = $conn->query("SELECT department, COUNT(*) as total FROM students GROUP BY department");
?>

